# .gcloudignore — controls what `gcloud builds submit` uploads as the build context.
#
# The mere existence of this file overrides .gitignore for gcloud, which is
# important: our .gitignore excludes `mcp-servers/piapi-mcp-server/` (we don't
# commit the built dist/ to git), but the backend/Dockerfile needs that
# directory at build time. Listing exclusions here — and NOT the mcp-server —
# makes the COPY in the Dockerfile succeed.

# ── Git metadata (huge, never needed in the image) ─────────────────────────
.git
.gitignore
.gitattributes

# ── IDE / editor ────────────────────────────────────────────────────────────
.vscode
.idea
.DS_Store
**/.DS_Store

# ── Claude / local tooling (never meant for remote builds) ──────────────────
.claude
.playwright-mcp
.qa-secrets

# ── Python ──────────────────────────────────────────────────────────────────
__pycache__
**/__pycache__
*.pyc
*.pyo
*.py[codz]
.venv
venv
env
*.egg-info
build
dist

# ── Node — reinstalled inside the Dockerfile ────────────────────────────────
node_modules
**/node_modules
# mcp-server node_modules + dist are regenerated by `npm install && npm run build`
# inside the Dockerfile, so we can skip them to slim the upload.
mcp-servers/piapi-mcp-server/node_modules
mcp-servers/piapi-mcp-server/dist

# ── Frontend ────────────────────────────────────────────────────────────────
# Full frontend not needed for backend builds, but include the source in case
# a future Dockerfile starts pulling from it. Just skip the huge node_modules.
frontend-vue/node_modules
frontend-vue/dist

# ── Docker local overrides (never push to prod build context) ───────────────
docker-compose.override.yml
docker-compose*.override.yml

# ── Secrets (defence in depth; .env should never ship anyway) ───────────────
/.env
.env
.envrc
backend/.env
backend/.env.local

# ── QA run artifacts / screenshots (local only) ─────────────────────────────
qa/runs
.pytest_cache

# ── Logs ────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
