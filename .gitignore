# =============================================================================
# Vidgo Gen AI — repo ignore rules
# Stack: Python (FastAPI backend) · Vue 3 (frontend-vue) · GCP / Cloud Run
# Frontend-specific rules also live in frontend-vue/.gitignore.
# =============================================================================

# ── OS / editor cruft ────────────────────────────────────────────────────────
.DS_Store
**/.DS_Store
# macOS AppleDouble / resource-fork files (._Foo) that appear on non-HFS volumes
._*
**/._*
Thumbs.db
*.bak
*.vue.bak
.vscode/
.idea/

# ── Secrets / local config (NEVER commit) ────────────────────────────────────
.env
/.env
.env.*
!.env.example
.envrc
.qa-secrets            # generated by gcp/seed-qa-personas.sh
*.pem
*.key
service-account*.json
gcp-key*.json

# ── Tooling / agents (local only) ────────────────────────────────────────────
.claude/

# ── Python: bytecode, build artifacts, caches ────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
build/
dist/
*.egg-info/
*.egg
.eggs/

# ── Python: virtualenvs ──────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/
**/.venv/
**/.venv-script/

# ── Python: test / type / lint caches ────────────────────────────────────────
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
coverage.xml
htmlcov/
.hypothesis/

# ── Node (root-level only; frontend-vue has its own) ─────────────────────────
node_modules/

# ── MCP server (built dist not committed; .gcloudignore re-includes for build) ─
mcp-servers/piapi-mcp-server/

# ── Logs / local databases ───────────────────────────────────────────────────
*.log
db.sqlite3
db.sqlite3-journal

# ── Generated / uploaded media (lives in Docker volumes + GCS, not git) ───────
**/static/generated/
**/static/materials/
**/static/models/
**/static/tryon_garments/
**/static/uploads/
**/static/temp_pregenerate/
