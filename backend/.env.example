# VidGo Backend Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!

# ===================
# Database
# ===================
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/vidgo

# ===================
# Redis
# ===================
REDIS_URL=redis://localhost:6379/0

# ===================
# Security
# ===================
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ===================
# Admin Bootstrap
# ===================
# Consumed by scripts/seed_test_user.py on first GCP deploy (run as a one-shot
# Cloud Run Job by gcp/full-deploy.sh). On GCP these are pulled from Secret
# Manager, never hardcoded. Set them here for local dev.
ADMIN_ACCOUNT=
ADMIN_PASSWORD=

# ===================
# AI Services
# ===================
# PiAPI (Text-to-Image with Flux, Virtual Try-On/Kling) - Get from: https://piapi.ai/
PIAPI_KEY=

# Optional: Public URL of your backend (e.g. https://api.example.com). If Virtual Try-On
# returns HTTP 500 with base64 model images, set this so model images are sent as URLs
# (PiAPI/Kling may require URLs). Backend must serve /static/ at this host.
# PUBLIC_APP_URL=https://api.example.com

# Pollo AI (Backup video: I2V, T2V) - Get from: https://pollo.ai/
POLLO_API_KEY=

# ───────────────────────────────────────────────────────────────────
# Provider model IDs (env-overridable — see app/core/model_registry.py)
# ───────────────────────────────────────────────────────────────────
# When PiAPI / Pollo ship a new model alias (e.g. Kling v3 → v4), bump
# the value here and roll-restart Cloud Run. No rebuild required.
# Leave blank to use the in-code defaults.
# PIAPI_KLING_EFFECTS_MODEL=kling
# PIAPI_KLING_TRYON_MODEL=kling
# PIAPI_KLING_AVATAR_MODEL=kling
# PIAPI_KLING_LIPSYNC_MODEL=kling
# PIAPI_TRELLIS_V1_MODEL=Qubico/trellis
# PIAPI_TRELLIS_V2_MODEL=Qubico/trellis2
# POLLO_PIXVERSE_DEFAULT_MODEL=pixverse_v4.5
# POLLO_PIXVERSE_CREATIVE_MODEL=pixverse_v5
# POLLO_KLING_VIDEO_MODEL=kling_v2
# POLLO_MCP_* env removed 2026-05-26 — Pollo MCP provider deleted in
# favor of the REST `pollo` provider (POLLO_API_KEY above).

# A2E.ai (Talking Avatar with Lip-Sync) - Get from: https://a2e.ai/
# API Documentation: https://api.a2e.ai/
# 1. Create account at https://video.a2e.ai/
# 2. Get API credentials from dashboard
# 3. Create an avatar (anchor) and get its creator_id
A2E_API_KEY=
A2E_API_ID=
A2E_DEFAULT_CREATOR_ID=

# Vertex AI (GCP) — Gemini for image backup + moderation, Veo for 3rd video backup
# 1. Create a GCP project and enable Vertex AI API
# 2. Set up Application Default Credentials (ADC):
#    - On GCP (Cloud Run/GKE): automatic via service account
#    - Local dev: run `gcloud auth application-default login` or set GOOGLE_APPLICATION_CREDENTIALS
VERTEX_AI_PROJECT=
VERTEX_AI_LOCATION=us-central1
VEO_MODEL=veo-3.0-generate-preview
GEMINI_MODEL=gemini-2.0-flash

# Legacy Gemini API key (fallback if Vertex AI not configured) - Get from: https://ai.google.dev/
GEMINI_API_KEY=

# YouTube (Google OAuth 2.0 for YouTube Data API v3) - Get from: https://console.cloud.google.com/
# 1. Create a project in Google Cloud Console
# 2. Enable YouTube Data API v3
# 3. Create OAuth 2.0 credentials (Web application)
# 4. Set authorized redirect URI to: {BACKEND_URL}/api/v1/social/oauth/youtube/callback
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=

# ===================
# Payment - ECPay (Taiwan)
# ===================
# Get credentials from: https://www.ecpay.com.tw/
# --- Test/Stage Credentials (for development) ---
# MerchantID: 3002607
# HashKey: pwFHCqoQZGmho4w6
# HashIV: EkRm7iFT261dpevs
# Test credit card: 4311-9511-1111-1111 (any 3-digit CVV, any future expiry date)
ECPAY_MERCHANT_ID=3002607
ECPAY_HASH_KEY=pwFHCqoQZGmho4w6
ECPAY_HASH_IV=EkRm7iFT261dpevs
# Use stage URL for testing, production URL for live
ECPAY_PAYMENT_URL=https://payment-stage.ecpay.com.tw/Cashier/AioCheckOut/V5

# ===================
# Payment - PayPal (International)
# ===================
# Get credentials from: https://developer.paypal.com/
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=
PAYPAL_WEBHOOK_SECRET=
PAYPAL_ENV=production
# Replace P-* values with the Live PayPal plan IDs from your PayPal app.
# Example IDs from PayPal button factory:
# basic_monthly=P-0SY53143DB278870HNIBOOBQ, basic_yearly=P-94S428737S896164XNIBOQ3Y
# pro_monthly=P-5P768152V1243720RNIBOPFY, pro_yearly=P-5YD13048BW888953SNIBORLY
# premium_monthly=P-7XL74550XD869973SNIBOP4A, premium_yearly=P-8KR590315K251371LNIBOR3I
PAYPAL_PLAN_IDS='{"basic_monthly":"P-BASIC-MONTHLY","basic_yearly":"P-BASIC-YEARLY","pro_monthly":"P-PRO-MONTHLY","pro_yearly":"P-PRO-YEARLY","premium_monthly":"P-PREMIUM-MONTHLY","premium_yearly":"P-PREMIUM-YEARLY","enterprise_monthly":"P-ENTERPRISE-MONTHLY","enterprise_yearly":"P-ENTERPRISE-YEARLY"}'

# ===================
# Object Storage (S3-compatible)
# ===================
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENDPOINT=

# ===================
# Demo Source Videos
# ===================
# Upload short videos (3-5 seconds, MP4, max 50MB) to cloud storage (S3, GCS, R2).
# Set a default video URL for all categories, or set per-category URLs.
DEMO_SOURCE_VIDEO_URL=
# Per-category video URLs (optional, falls back to DEMO_SOURCE_VIDEO_URL)
DEMO_VIDEO_ANIMALS=
DEMO_VIDEO_NATURE=
DEMO_VIDEO_URBAN=
DEMO_VIDEO_PEOPLE=
DEMO_VIDEO_FANTASY=
DEMO_VIDEO_SCIFI=
DEMO_VIDEO_FOOD=
DEMO_VIDEO_DEFAULT=

# ===================
# App Settings
# ===================
DEBUG=true
WATERMARK_TEXT=VidGo Demo

# ===================
# Pre-generation Pipeline
# ===================
# These control the startup pre-generation behavior.
# See README.md for full documentation.

# Skip pre-generation entirely (use existing materials)
SKIP_PREGENERATION=false

# Maximum materials to generate per tool on startup
PREGENERATION_LIMIT=10

# Skip avatar generation to save A2E API costs (set to any value to skip)
# SKIP_AVATAR=true

# Skip video generation to save Pollo API costs (set to any value to skip)
# SKIP_VIDEO=true

# Skip Virtual Try-On in material seeding when PiAPI/Kling is down (set to any value to skip)
# SKIP_TRY_ON=true
# Troubleshooting Try-On HTTP 500: (1) Check PiAPI key has Kling Try-On access.
# (2) Model/garment images must meet Kling guidelines (see piapi.ai/docs). (3) If using
# local model images, set PUBLIC_APP_URL so PiAPI receives URLs instead of base64.

# Minimum templates required per group for startup validation
MIN_TEMPLATES=1

# Startup validation timeout in seconds
STARTUP_TIMEOUT=300

# ===================
# Email Configuration
# ===================
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@vidgo.ai
SMTP_FROM_NAME=VidGo
SMTP_TLS=true

# Email Verification
EMAIL_VERIFICATION_EXPIRE_HOURS=24
FRONTEND_URL=http://localhost:5173
# Backend URL (must be publicly accessible for ECPay callbacks)
# For local testing with ngrok: BACKEND_URL=https://your-ngrok-url.ngrok.io
BACKEND_URL=http://localhost:8000

# ─── Referral System ────────────────────────────────────────────────────────
# Credits awarded to the referrer when someone they invited registers
REFERRAL_BONUS_CREDITS=50
# Credits awarded to the newly registered user who used a referral code
REFERRAL_WELCOME_CREDITS=20

# ─── Subscriber Upload Settings ─────────────────────────────────────────────
# Maximum file size in MB for subscriber material uploads
MAX_UPLOAD_SIZE_MB=20
# Allowed MIME types for uploads (comma-separated)
UPLOAD_ALLOWED_TYPES=image/jpeg,image/png,image/webp,image/gif

# ─── Model Credit Multipliers ────────────────────────────────────────────────
# JSON map of model_id → credit multiplier (applied on top of base tool cost)
# e.g. kling_v2 costs 2× the base credit price of the tool
MODEL_CREDIT_MULTIPLIERS={"default":1,"kling_v2":2,"luma_ray2":3,"pixverse_v5":1.5,"wan_pro":2}
