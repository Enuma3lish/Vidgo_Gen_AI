            </RouterLink>
            <RouterLink v-if="!authStore.isAdmin" to="/dashboard/my-works" class="hidden md:inline-flex items-center gap-1.5 px-3 py-1.5 text-sm font-medium rounded-lg transition-colors" style="color: #475569;" @mouseenter="($event.target as HTMLElement).style.color='#0f172a'" @mouseleave="($event.target as HTMLElement).style.color='#475569'">
