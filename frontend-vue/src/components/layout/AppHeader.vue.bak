<script setup lang="ts">
import { computed, ref, onMounted, onUnmounted } from 'vue'
import { RouterLink, useRouter } from 'vue-router'
import { useI18n } from 'vue-i18n'
import { useAuthStore, useCreditsStore } from '@/stores'
import LanguageSelector from './LanguageSelector.vue'

const { t } = useI18n()
const router = useRouter()
const authStore = useAuthStore()
const creditsStore = useCreditsStore()
const isScrolled = ref(false)
const mobileMenuOpen = ref(false)
const toolsOpen = ref(false)
const showCreditBadge = computed(() => authStore.isAuthenticated && !authStore.isAdmin)

function handleScroll() {
  isScrolled.value = window.scrollY > 10
}
function handleLogout() {
  authStore.logout()
  router.push('/')
}
onMounted(async () => {
  if (authStore.isAuthenticated && !authStore.isAdmin) {
    try { await creditsStore.fetchBalance() } catch {}
  }
  window.addEventListener('scroll', handleScroll)
  handleScroll()
})
onUnmounted(() => {
  window.removeEventListener('scroll', handleScroll)
})
</script>

<template>
  <header
    class="fixed top-0 left-0 right-0 z-50 transition-all duration-300"
    :style="isScrolled
      ? 'background: rgba(255,255,255,0.96); backdrop-filter: blur(18px); box-shadow: 0 1px 0 rgba(15,23,42,0.08), 0 10px 30px rgba(15,23,42,0.06);'
      : 'background: rgba(255,255,255,0.88); backdrop-filter: blur(12px); box-shadow: 0 1px 0 rgba(15,23,42,0.05);'"
  >
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between h-16">

        <!-- Logo -->
        <RouterLink to="/" class="flex items-center gap-2.5 flex-shrink-0">
          <div class="w-8 h-8 rounded-lg flex items-center justify-center font-black text-white text-sm"
            style="background: linear-gradient(135deg, #1677ff, #0958d9);">
            V
          </div>
          <span class="text-lg font-black tracking-tight" style="color: #0f172a;">VidGo <span style="color: #1677ff;">AI</span></span>
        </RouterLink>

        <!-- Center Nav -->
        <nav class="hidden md:flex items-center gap-1">
          <RouterLink to="/" class="nav-link rounded-lg" active-class="!text-primary-600">
            {{ t('nav.home') }}
          </RouterLink>

          <RouterLink to="/gallery" class="nav-link rounded-lg" active-class="!text-primary-600">
            {{ t('gallery.title') }}
          </RouterLink>

          <!-- Tools Dropdown -->
          <div class="relative" @mouseenter="toolsOpen = true" @mouseleave="toolsOpen = false">
            <button class="nav-link rounded-lg flex items-center gap-1">
              {{ t('nav.tools') }}
              <svg class="w-3.5 h-3.5 mt-0.5 transition-transform" :class="toolsOpen ? 'rotate-180' : ''" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
              </svg>
            </button>
            <div
              v-show="toolsOpen"
              class="absolute top-full left-1/2 -translate-x-1/2 pt-2 w-[calc(100vw-2rem)] md:w-[760px]"
            >
              <div class="rounded-xl overflow-hidden dropdown-menu">
              <div class="grid grid-cols-4 gap-0 p-4">
                <!-- Fashion & Video Column -->
                <div>
                  <div class="px-3 py-1.5 text-xs font-bold uppercase tracking-wider" style="color: #64748b;">{{ t('lp.categories.fashionAI') }}</div>
                  <RouterLink to="/tools/try-on" class="dropdown-item" @click="toolsOpen = false">
                    <span>👗</span><span class="font-medium" style="color: #0f172a;">{{ t('lp.allTools.tryOn.name') }}</span>
                  </RouterLink>
                  <RouterLink to="/tools/short-video" class="dropdown-item" @click="toolsOpen = false">
                    <span>🎬</span><span class="font-medium" style="color: #0f172a;">{{ t('lp.allTools.fashionReels.name') }}</span>
                  </RouterLink>
                  <RouterLink to="/tools/avatar" class="dropdown-item" @click="toolsOpen = false">
                    <span>🗣️</span><span class="font-medium" style="color: #0f172a;">{{ t('lp.allTools.productAvatars.name') }}</span>
                  </RouterLink>
                </div>
                <!-- E-commerce AI Column -->
                <div>
                  <div class="px-3 py-1.5 text-xs font-bold uppercase tracking-wider" style="color: #64748b;">{{ t('lp.categories.ecommerceAI') }}</div>
                  <RouterLink to="/tools/product-scene" class="dropdown-item" @click="toolsOpen = false">
                    <span>📸</span><span class="font-medium" style="color: #0f172a;">{{ t('lp.allTools.productAnyshoot.name') }}</span>
                  </RouterLink>
                  <RouterLink to="/tools/background-removal" class="dropdown-item" @click="toolsOpen = false">
                    <span>✂️</span><span class="font-medium" style="color: #0f172a;">{{ t('lp.allTools.bgRemoval.name') }}</span>
                  </RouterLink>
                  <RouterLink to="/tools/upscale" class="dropdown-item" @click="toolsOpen = false">
                    <span>🔍</span><span class="font-medium" style="color: #0f172a;">{{ t('lp.allTools.hdUpscale.name') }}</span>
                  </RouterLink>
                  <RouterLink to="/tools/pattern-generate" class="dropdown-item" @click="toolsOpen = false">
                    <span>▦</span><span class="font-medium" style="color: #0f172a;">{{ t('lp.allTools.patternGenerate.name') }}</span>
                  </RouterLink>
                </div>
                <!-- Design & Effects Column -->
                <div>
                  <div class="px-3 py-1.5 text-xs font-bold uppercase tracking-wider" style="color: #64748b;">{{ t('lp.categories.designAI') }}</div>
                  <RouterLink to="/tools/room-redesign" class="dropdown-item" @click="toolsOpen = false">
                    <span>🏠</span><span class="font-medium" style="color: #0f172a;">{{ t('lp.allTools.roomRedesign.name') }}</span>
                  </RouterLink>
                  <RouterLink to="/tools/video-transform" class="dropdown-item" @click="toolsOpen = false">
                    <span>🎞️</span><span class="font-medium" style="color: #0f172a;">{{ t('lp.allTools.videoTransform.name') }}</span>
                  </RouterLink>
                  <RouterLink to="/gallery" class="dropdown-item" @click="toolsOpen = false">
                    <span>🖼️</span><span class="font-medium" style="color: #0f172a;">{{ t('gallery.title') }}</span>
                  </RouterLink>
                </div>
                <!-- Localization Column -->
                <div>
                  <div class="px-3 py-1.5 text-xs font-bold uppercase tracking-wider" style="color: #64748b;">{{ t('lp.imageTranslation.title') }}</div>
                  <RouterLink to="/tools/image-translator" class="dropdown-item" @click="toolsOpen = false">
                    <span>文</span><span class="font-medium" style="color: #0f172a;">{{ t('lp.allTools.imageTranslator.name') }}</span>
                  </RouterLink>
                  <RouterLink to="/tools/video-dubbing" class="dropdown-item" @click="toolsOpen = false">
                    <span>🎙️</span><span class="font-medium" style="color: #0f172a;">{{ t('lp.videoDubbing.title') }}</span>
                  </RouterLink>
                </div>
              </div>
              </div>
            </div>
          </div>

          <RouterLink to="/pricing" class="nav-link rounded-lg" active-class="!text-primary-600">
            {{ t('nav.pricing') }}
          </RouterLink>
